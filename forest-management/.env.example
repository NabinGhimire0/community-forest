# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_PORT=8080
APP_ENV=development
APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# PostgreSQL
# Local Docker defaults only. Use a unique secret and TLS in production.
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=admin123
DB_NAME=forest_management
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_MINUTES=30
RUN_AUTO_MIGRATE=true
ALLOW_INSECURE_DB=false

# -----------------------------------------------------------------------------
# Browser origins, reverse proxy and session security
# Production examples must use HTTPS and exact origins (never *).
# TRUSTED_PROXIES accepts comma-separated IPs/CIDRs for your own reverse proxy.
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173
PUBLIC_BACKEND_URL=http://localhost:8080
TRUSTED_PROXIES=
SESSION_COOKIE_NAME=bansamiti_session
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
SESSION_HOURS=12
SESSION_IDLE_MINUTES=60

# Generate a unique key; never reuse the example or commit the real key:
# Linux/macOS: openssl rand -base64 32
# PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Max 256 }))
DATA_ENCRYPTION_KEY=
REQUIRE_PRIVILEGED_MFA=false

# -----------------------------------------------------------------------------
# Abuse protection
# Use Nginx/API-gateway/Redis rate limiting as an additional layer in a
# multi-instance production deployment.
# -----------------------------------------------------------------------------
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
RATE_LIMIT_PER_MINUTE=180
MAX_JSON_BODY_BYTES=2097152

# -----------------------------------------------------------------------------
# Private file storage and malware scanning
# Files should be on an encrypted, backed-up volume outside any public web root.
# Production startup requires ClamAV and REQUIRE_ANTIVIRUS=true.
# Example ClamAV TCP address: 127.0.0.1:3310
# -----------------------------------------------------------------------------
UPLOAD_DIR=./uploads
CLAMAV_ADDR=
REQUIRE_ANTIVIRUS=false

# -----------------------------------------------------------------------------
# Exports and encrypted backups
# pg_dump should match or be newer than the PostgreSQL server major version.
# BACKUP_TEMP_DIR should be on an encrypted filesystem with adequate free space.
# -----------------------------------------------------------------------------
PG_DUMP_PATH=pg_dump
BACKUP_TEMP_DIR=
BACKUP_TIMEOUT_MINUTES=15
EXPORT_MAX_ROWS=250000

# -----------------------------------------------------------------------------
# eSewa ePay v2 UAT/test configuration
# Production validation rejects test mode, EPAYTEST and rc-* endpoints.
# -----------------------------------------------------------------------------
ESEWA_MODE=test
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_FORM_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
ESEWA_STATUS_URL=https://rc.esewa.com.np/api/epay/transaction/status/

# -----------------------------------------------------------------------------
# SMS is intentionally disabled until a real provider integration is completed.
# Temporary passwords are shown once to the authenticated admin and must be
# handed over through a trusted channel.
# -----------------------------------------------------------------------------
SMS_PROVIDER=disabled
SMS_API_KEY=
SMS_SENDER_ID=BanSamiti

# -----------------------------------------------------------------------------
# One-time bootstrap administrator
# Use a unique phone and a strong password of at least 12 characters. The account
# is forced to change its password and is disabled after a real committee admin
# is created.
# -----------------------------------------------------------------------------
SEED_ADMIN_NAME=Bootstrap Administrator
SEED_ADMIN_PHONE=
SEED_ADMIN_PASSWORD=

# Initial organization settings stored in PostgreSQL
SEED_SAMITI_NAME=श्री पाञ्चकन्या सामुदायिक वन उपभोक्ता समूह
SEED_SAMITI_REGISTRATION_NO=८३
SEED_SAMITI_ADDRESS=धरान-६, पानबारी, सुनसरी, कोशी प्रदेश
SEED_SAMITI_WARD_NO=6
SEED_SAMITI_MUNICIPALITY=धरान उपमहानगरपालिका
SEED_SAMITI_DISTRICT=सुनसरी
SEED_SAMITI_PROVINCE=कोशी प्रदेश
