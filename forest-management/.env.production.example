# Copy to a root-controlled secret file outside the repository. Replace every
# placeholder. Do not commit the completed file.
APP_PORT=8080
APP_ENV=production
APP_VERSION=1.0.0

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=bansamiti_app
DB_PASSWORD=<unique-strong-database-password>
DB_NAME=forest_management
DB_SSLMODE=require
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_MINUTES=30
RUN_AUTO_MIGRATE=false
ALLOW_INSECURE_DB=false

CORS_ORIGINS=https://forest.example.org
FRONTEND_URL=https://forest.example.org
PUBLIC_BACKEND_URL=https://forest.example.org
TRUSTED_PROXIES=127.0.0.1
SESSION_COOKIE_NAME=__Host-bansamiti_session
COOKIE_DOMAIN=
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
SESSION_HOURS=12
SESSION_IDLE_MINUTES=60
DATA_ENCRYPTION_KEY=<base64-encoded-32-byte-key>
REQUIRE_PRIVILEGED_MFA=true

LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
RATE_LIMIT_PER_MINUTE=180
MAX_JSON_BODY_BYTES=2097152

UPLOAD_DIR=/srv/bansamiti/uploads
CLAMAV_ADDR=127.0.0.1:3310
REQUIRE_ANTIVIRUS=true

PG_DUMP_PATH=/usr/bin/pg_dump
BACKUP_TEMP_DIR=/srv/bansamiti/backup-temp
BACKUP_TIMEOUT_MINUTES=30
EXPORT_MAX_ROWS=250000

ESEWA_MODE=live
ESEWA_PRODUCT_CODE=<live-merchant-product-code>
ESEWA_SECRET_KEY=<live-esewa-secret>
ESEWA_FORM_URL=<official-live-esewa-form-url>
ESEWA_STATUS_URL=<official-live-esewa-status-url>

SMS_PROVIDER=disabled
SMS_API_KEY=
SMS_SENDER_ID=BanSamiti

# Needed only while running the one-time seed command. Remove these values from
# the long-running API service environment after the real administrator exists.
SEED_ADMIN_NAME=Bootstrap Administrator
SEED_ADMIN_PHONE=
SEED_ADMIN_PASSWORD=

SEED_SAMITI_NAME=श्री पाञ्चकन्या सामुदायिक वन उपभोक्ता समूह
SEED_SAMITI_REGISTRATION_NO=८३
SEED_SAMITI_ADDRESS=धरान-६, पानबारी, सुनसरी, कोशी प्रदेश
SEED_SAMITI_WARD_NO=6
SEED_SAMITI_MUNICIPALITY=धरान उपमहानगरपालिका
SEED_SAMITI_DISTRICT=सुनसरी
SEED_SAMITI_PROVINCE=कोशी प्रदेश
